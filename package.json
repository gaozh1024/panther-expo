{
  "name": "@panther-expo/monorepo",
  "private": true,
  "description": "Panther Expo Framework Monorepo",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "clean": "pnpm -r clean",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "template:pack": "cd templates/rn-starter && npm pack",
    "template:publish": "cd templates/rn-starter && npm publish --access public",
    "test-app": "cd examples/test-app && npm start",
    "yalc:publish": "pnpm -r --filter='@panther-expo/*' exec yalc publish",
    "yalc:push": "pnpm -r --filter='@panther-expo/*' exec yalc push",
    "yalc:update": "pnpm -r --filter='@panther-expo/*' exec yalc push --replace"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "typescript": "~5.9.2"
  },
  "workspaces": [
    "packages/*",
    "templates/*",
    "examples/*"
  ]
}
