{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": ".",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "strictFunctionTypes": false,
    "paths": {
      "@panther-expo/theme": ["../theme/dist"],
      "@panther-expo/theme/*": ["../theme/dist/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
